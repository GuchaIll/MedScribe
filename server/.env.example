# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
DEBUG=True

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medscribe

# Database connection pool settings
DB_ECHO=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# REDIS (Session Management - Post-MVP)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password

# =============================================================================
# STORAGE
# =============================================================================
# Storage backend: local, s3, gcp, azure
STORAGE_BACKEND=local
STORAGE_BASE_DIR=storage

# AWS S3 Configuration (for production - post-MVP)
# S3_BUCKET=medscribe-production
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Field-level encryption for PHI
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your_fernet_encryption_key

# =============================================================================
# EXTERNAL APIs
# =============================================================================

# LLM PROVIDER CONFIGURATION
# Set at least ONE of the following API keys. If multiple are set, the user can
# select which one to use in the frontend. If not selected, the app prioritizes:
# 1. Groq (if GROQ_API_KEY is set)
# 2. OpenAI (if OPENAI_API_KEY is set)
# 3. Anthropic (if ANTHROPIC_API_KEY is set)
# 4. Google (if GOOGLE_API_KEY is set)
# 5. OpenRouter (if OPENROUTER_API_KEY is set)

# Groq API for LLM inference (fast, free tier available)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI GPT API (gpt-4-turbo-preview)
OPENAI_API_KEY=sk_your_openai_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk_ant_your_anthropic_api_key_here

# Google Gemini API
GOOGLE_API_KEY=your_google_gemini_api_key_here

# OpenRouter API (access to 100+ open source models)
OPENROUTER_API_KEY=sk_or_your_openrouter_api_key_here

# (Optional) Explicitly select an LLM provider at startup
# If not set, the app will auto-select based on available keys
# Options: groq, openai, anthropic, google, openrouter
LLM_PROVIDER=

# HuggingFace for model downloads and diarization (optional)
HUGGINGFACE_API_KEY=hf_your_huggingface_api_key_here
HF_TOKEN=hf_your_huggingface_token_here

# ElevenLabs for text-to-speech (optional)
ELEVEN_LABS_API_KEY=sk_your_elevenlabs_api_key_here

# =============================================================================
# LLM AND MODEL CONFIGURATION
# =============================================================================
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_CLINICAL_SUGGESTIONS=True
ENABLE_HUMAN_REVIEW=True
ENABLE_AUDIT_LOGGING=True

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Medical Transcription API
APP_VERSION=1.0.0-mvp
API_PREFIX=/api

# =============================================================================
# CORS SETTINGS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=True

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# WORKFLOW SETTINGS
# =============================================================================
CHECKPOINT_DB_PATH=storage/checkpoints.db
MAX_WORKFLOW_RETRIES=3
WORKFLOW_TIMEOUT_SECONDS=300

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# For production deployment:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=False
# 3. Generate strong SECRET_KEY and ENCRYPTION_KEY
# 4. Use managed database (AWS RDS, GCP Cloud SQL)
# 5. Use managed Redis (AWS ElastiCache, GCP Memorystore)
# 6. Configure S3 or cloud storage
# 7. Use AWS Secrets Manager or similar for sensitive values
# 8. Enable TLS/HTTPS
# 9. Set appropriate CORS_ORIGINS
# 10. Review and enable all security features
