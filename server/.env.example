# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
DEBUG=True

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medscribe

# Database connection pool settings
DB_ECHO=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# REDIS (Session Management - Post-MVP)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password

# =============================================================================
# STORAGE
# =============================================================================
# Storage backend: local, s3, gcp, azure
STORAGE_BACKEND=local
STORAGE_BASE_DIR=storage

# AWS S3 Configuration (for production - post-MVP)
# S3_BUCKET=medscribe-production
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Field-level encryption for PHI
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your_fernet_encryption_key

# =============================================================================
# EXTERNAL APIs
# =============================================================================
# Groq API for LLM inference
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace for model downloads and diarization
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HF_TOKEN=your_huggingface_token_here

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
# LLM_MODEL: "local" for Phi-3, "api" for Groq
LLM_MODEL=api
LLM_MAX_BUDGET=30
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.1

# =============================================================================
# WHISPER CONFIGURATION
# =============================================================================
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_CLINICAL_SUGGESTIONS=True
ENABLE_HUMAN_REVIEW=True
ENABLE_AUDIT_LOGGING=True

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Medical Transcription API
APP_VERSION=1.0.0-mvp
API_PREFIX=/api

# =============================================================================
# CORS SETTINGS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=True

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# WORKFLOW SETTINGS
# =============================================================================
CHECKPOINT_DB_PATH=storage/checkpoints.db
MAX_WORKFLOW_RETRIES=3
WORKFLOW_TIMEOUT_SECONDS=300

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# For production deployment:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=False
# 3. Generate strong SECRET_KEY and ENCRYPTION_KEY
# 4. Use managed database (AWS RDS, GCP Cloud SQL)
# 5. Use managed Redis (AWS ElastiCache, GCP Memorystore)
# 6. Configure S3 or cloud storage
# 7. Use AWS Secrets Manager or similar for sensitive values
# 8. Enable TLS/HTTPS
# 9. Set appropriate CORS_ORIGINS
# 10. Review and enable all security features
