# MedScribe — Environment Configuration
#
# Copy this file to .env in the project root:
#   cp .env.example .env
#
# Then fill in your actual values. At minimum you need:
#   1. At least one LLM API key
#   2. A SECRET_KEY for JWT signing
#
# DO NOT commit .env to version control.

# =============================================================================
# LLM PROVIDER KEYS  (set at least one)
# =============================================================================
# If multiple keys are present the app auto-selects in priority order:
#   groq -> openai -> anthropic -> google -> openrouter
# Override with LLM_PROVIDER below.

GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# (Optional) Force a specific provider instead of auto-select.
# Values: groq | openai | anthropic | google | openrouter
# LLM_PROVIDER=

# =============================================================================
# SECURITY
# =============================================================================
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# Go gateway JWT signing key (HMAC-SHA256).
# Generate with:  openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME

# AES-256-GCM key for PHI field-level encryption (32 hex bytes).
# Generate with:  openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME

# =============================================================================
# INFRASTRUCTURE  (docker-compose overrides these per-service)
# =============================================================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medscribe

# Redis — used for pipeline status + session cache
REDIS_URL=redis://localhost:6379/0

# Kafka broker list (comma-separated for clusters)
KAFKA_BROKERS=localhost:9092

# =============================================================================
# STRANGLER-FIG BRIDGE  (Go gateway -> Python pipeline)
# =============================================================================
# Internal URL the Go gateway uses to forward pipeline requests to Python.
# In docker-compose this is overridden to http://api:3001.
PYTHON_BACKEND_URL=http://localhost:3001

# Kafka consumer group for the pipeline proxy consumer.
KAFKA_CONSUMER_GROUP=medscribe-pipeline-proxy

# Max time the Go proxy waits for a single Python pipeline run.
PYTHON_PIPELINE_TIMEOUT=5m

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# ElevenLabs text-to-speech (falls back to browser SpeechSynthesis if omitted)
# ELEVEN_LABS_API_KEY=

# HuggingFace — only needed if you enable local embedding or diarisation models
# HUGGINGFACE_API_KEY=
# HF_TOKEN=
