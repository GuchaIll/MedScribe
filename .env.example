# MedScribe — Environment Configuration
#
# Copy this file to .env in the project root:
#   cp .env.example .env
#
# Then fill in your actual values. At minimum you need:
#   1. At least one LLM API key
#   2. A SECRET_KEY for JWT signing
#
# DO NOT commit .env to version control.

# =============================================================================
# LLM PROVIDER KEYS  (set at least one)
# =============================================================================
# If multiple keys are present the app auto-selects in priority order:
#   groq -> openai -> anthropic -> google -> openrouter
# Override with LLM_PROVIDER below.

GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# (Optional) Force a specific provider instead of auto-select.
# Values: groq | openai | anthropic | google | openrouter
# LLM_PROVIDER=

# =============================================================================
# SECURITY
# =============================================================================
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# ElevenLabs text-to-speech (falls back to browser SpeechSynthesis if omitted)
# ELEVEN_LABS_API_KEY=

# HuggingFace — only needed if you enable local embedding or diarisation models
# HUGGINGFACE_API_KEY=
# HF_TOKEN=
